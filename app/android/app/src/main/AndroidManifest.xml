<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!-- Outfit Advisor Phase 2: the briefly-visible wake screen launched by the
             full-screen-intent notification at the armed morning time. -->
        <activity
            android:name=".WakeActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.OutfitWake" />

        <!-- Daily exact-alarm fire -> re-arm + FSI wake. -->
        <receiver
            android:name=".AlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.korety.outfitadvisor.FIRE" />
            </intent-filter>
        </receiver>

        <!-- Re-arm the alarm after a reboot. exported=false is safe: BOOT_COMPLETED
             is a protected broadcast only the system can send, and the system is
             exempt from the export restriction — other apps can't poke this. -->
        <receiver
            android:name=".BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Closet (C2): photograph clothes for LLM classification. Camera stays
         optional hardware — gallery upload covers camera-less devices. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <!-- Trips: read the device calendar to spot upcoming trips. MUST be declared
         HERE — @ebarooni/capacitor-calendar ships an EMPTY manifest and injects
         nothing, so without this line the first CalendarContract query throws
         SecurityException even though the JS permission prompt appears to succeed.
         READ only — never WRITE_CALENDAR; we only ever use the plugin's
         `readCalendar` permission alias. Event text never leaves the phone. -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <!-- Background location (ADDED 2026-07-15 at explicit user request — reverses
         the original "deliberately NO" decision, see PLAN). Declaring it is what
         makes "Allow all the time" appear in Android's settings at all. The FSI
         visible-activity wake stays as the notification vehicle; this grant
         removes the GPS read's dependency on the wake screen actually becoming
         visible before the fix is requested. Requested via the OutfitAlarm
         plugin's bgLocation({request:true}) — never at first launch. -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- androidx.work adds three uses-permissions of its own via manifest merger.
         Two are load-bearing and stay — WorkManager cannot run a job without them:
             WAKE_LOCK            — held while a worker runs
             ACCESS_NETWORK_STATE — backs its network constraints
         One is NOT used by our path and is removed, because a library should not get
         to widen this app's permission list by default:
             FOREGROUND_SERVICE — only needed for EXPEDITED work. PackingWorker is
                 ordinary one-time work (a packing push days out is not time-critical),
                 so this is dead weight. If anyone ever adds .setExpedited(), they
                 must restore this — and on targetSdk 34 also declare a
                 foregroundServiceType.
         Removal verified against the BUILT APK's merged manifest, not just asserted.

         NB: DUMP and BIND_JOB_SERVICE also appear in the merged manifest, but they
         are NOT requested by the app — they are `android:permission` GUARDS on
         WorkManager's own DiagnosticsReceiver and SystemJobService, constraining who
         may call in (adb / the system). They are protections, not requests, and
         must be left alone. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"
        tools:node="remove" />
</manifest>
